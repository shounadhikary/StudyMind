# StudyMind environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. All AI/secret keys are used server-side only.

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- AI providers ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Database & storage (Supabase / PostgreSQL + pgvector) ---
# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From Supabase: Project Settings -> Database -> Connection string.
# URL-encode special characters in the password (e.g. % -> %25).
# DATABASE_URL = Transaction pooler (port 6543) — app runtime.
# DIRECT_URL   = Session pooler (port 5432) — Prisma migrations (DDL).
# Also enable the `vector` extension: Database -> Extensions -> vector.
DATABASE_URL=
DIRECT_URL=
