# StudyMind environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`. All AI/secret keys are used server-side only.

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- AI providers ---
GEMINI_API_KEY=
GROQ_API_KEY=

# --- Database & storage (Supabase / PostgreSQL + pgvector) ---
# From Supabase: Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From Supabase: Project Settings -> Database -> Connection string -> URI.
# Use the "Session pooler" (port 5432) string — it works for both Prisma
# migrations and app runtime. Remember to URL-encode special chars in the password.
# Also enable the `vector` extension: Database -> Extensions -> vector.
DATABASE_URL=
